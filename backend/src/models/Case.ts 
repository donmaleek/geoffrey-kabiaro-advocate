import mongoose, { Schema, Document } from 'mongoose';

export interface ICase extends Document {
  caseNumber: string;
  clientId: mongoose.Types.ObjectId;
  lawyerId: mongoose.Types.ObjectId;
  title: string;
  type: 'litigation' | 'corporate' | 'family' | 'land' | 'employment' | 'criminal';
  status: 'active' | 'pending' | 'closed' | 'archived';
  priority: 'low' | 'medium' | 'high' | 'urgent';
  court?: string;
  judge?: string;
  nextHearing?: Date;
  documents: Array<{
    name: string;
    url: string;
    uploadedAt: Date;
    uploadedBy: mongoose.Types.ObjectId;
  }>;
  messages: Array<{
    senderId: mongoose.Types.ObjectId;
    content: string;
    createdAt: Date;
    attachments?: string[];
  }>;
  timeline: Array<{
    date: Date;
    action: string;
    description: string;
    userId: mongoose.Types.ObjectId;
  }>;
  fees: {
    total: number;
    paid: number;
    outstanding: number;
    payments: Array<{
      amount: number;
      date: Date;
      transactionId: string;
      method: 'mpesa' | 'bank' | 'cash';
    }>;
  };
  aiPredictions?: {
    successProbability: number;
    estimatedDuration: number;
    factors: string[];
  };
  createdAt: Date;
  updatedAt: Date;
}

const CaseSchema = new Schema<ICase>({
  caseNumber: {
    type: String,
    required: true,
    unique: true
  },
  clientId: {
    type: Schema.Types.ObjectId,
    ref: 'User',
    required: true
  },
  lawyerId: {
    type: Schema.Types.ObjectId,
    ref: 'User',
    required: true
  },
  title: {
    type: String,
    required: true
  },
  type: {
    type: String,
    enum: ['litigation', 'corporate', 'family', 'land', 'employment', 'criminal'],
    required: true
  },
  status: {
    type: String,
    enum: ['active', 'pending', 'closed', 'archived'],
    default: 'pending'
  },
  priority: {
    type: String,
    enum: ['low', 'medium', 'high', 'urgent'],
    default: 'medium'
  },
  court: String,
  judge: String,
  nextHearing: Date,
  documents: [{
    name: String,
    url: String,
    uploadedAt: {
      type: Date,
      default: Date.now
    },
    uploadedBy: {
      type: Schema.Types.ObjectId,
      ref: 'User'
    }
  }],
  messages: [{
    senderId: {
      type: Schema.Types.ObjectId,
      ref: 'User'
    },
    content: String,
    createdAt: {
      type: Date,
      default: Date.now
    },
    attachments: [String]
  }],
  timeline: [{
    date: {
      type: Date,
      default: Date.now
    },
    action: String,
    description: String,
    userId: {
      type: Schema.Types.ObjectId,
      ref: 'User'
    }
  }],
  fees: {
    total: {
      type: Number,
      default: 0
    },
    paid: {
      type: Number,
      default: 0
    },
    outstanding: {
      type: Number,
      default: 0
    },
    payments: [{
      amount: Number,
      date: {
        type: Date,
        default: Date.now
      },
      transactionId: String,
      method: {
        type: String,
        enum: ['mpesa', 'bank', 'cash']
      }
    }]
  },
  aiPredictions: {
    successProbability: Number,
    estimatedDuration: Number,
    factors: [String]
  }
}, {
  timestamps: true
});

// Calculate outstanding fees before saving
CaseSchema.pre('save', function(next) {
  if (this.isModified('fees')) {
    this.fees.outstanding = this.fees.total - this.fees.paid;
  }
  next();
});

export default mongoose.model<ICase>('Case', CaseSchema);